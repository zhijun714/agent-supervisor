# Feishu (Lark) integration — required for comm adapter
# Copy to .env and fill in your values, OR export as shell env vars before starting the server.
#
# How to get these values:
# 1. Go to https://open.feishu.cn/app and create or select your app
# 2. App ID and App Secret are in the "Credentials & Basic Info" section
# 3. Enable "Receive Messages" event subscription (im.message.receive_v1)
# 4. Set up the app as a bot (enable "Use Bot" feature)
# 5. Add the bot to your target chat / group

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PORT (optional, defaults to 3458)
# PORT=3458
